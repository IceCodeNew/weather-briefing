# Keep values unquoted for compatibility with docker run --env-file.
# python-dotenv and Docker Compose accept quoted values, but Docker CLI
# can pass the wrapping quotes into the container as literal characters.

# Required: select an any-llm provider and model. Provider credentials and API
# bases use the environment names documented by any-llm for that provider.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
# Optional request-failure fallback, disabled by default. Configure both values
# or neither.
# LLM_FALLBACK_PROVIDER=openai
# LLM_FALLBACK_MODEL=gpt-5-mini
# DeepSeek example. DEEPSEEK_API_BASE is optional.
DEEPSEEK_API_KEY=replace-in-runtime-environment
# DEEPSEEK_API_BASE=

# Set to true for verbose application diagnostics. Logs are written to stderr.
DEBUG=false

PUBLISHER=telegram
# Required when PUBLISHER=telegram; optional for other publishers.
# For initial testing, set PUBLISHER=stdout to print briefings to stdout
# instead of sending via Telegram.
# TELEGRAM_BOT_TOKEN=replace-in-runtime-environment
# TELEGRAM_CHAT_ID=replace-in-runtime-environment

# BARK_DEVICE_KEY is required when PUBLISHER=bark. Encryption is optional.
# BARK_DEVICE_KEY=replace-in-runtime-environment
# Optional: use a self-hosted Bark server instead of https://api.day.app.
# BARK_BASE_URL=https://bark.example.com
# Optional notification grouping.
# BARK_GROUP=weather-briefing
# Encryption is recommended. Configure the Bark app for AES256, GCM, noPadding,
# and the same initial IV. Each push uses a new IV sent with its ciphertext.
# See: https://bark.day.app/#/encryption
# Generate AES256 values on Linux:
#   openssl rand -hex 16  # key: 32 ASCII characters
#   openssl rand -hex 6   # IV: 12 ASCII characters
# BARK_ENCRYPTION_KEY=replace-in-runtime-environment
# BARK_ENCRYPTION_IV=replace-in-runtime-environment

# Optional global generation overrides. Choose values for the selected
# PUBLISHER. For Bark, the character limit is a one-message target and Bark
# allows at most twice that length.
# BRIEFING_MAX_CHARACTERS=650
# LLM_MAX_OUTPUT_TOKENS=4096
# For Telegram and stdout:
# BRIEFING_MAX_CHARACTERS=3500
# LLM_MAX_OUTPUT_TOKENS=8192
LLM_MAX_ATTEMPTS=3

# Application scheduler timezone. The Docker startup example also passes this
# value to the container as TZ.
BRIEFING_TIMEZONE=Asia/Shanghai
# Optional: BRIEFING_CRON accepts an APScheduler cron expression
# for the hour field, such as 9-23 or */2.
GREETING_HOUR=8
GREETING_MINUTE=0
BRIEFING_CRON=9-23

# Optional explicit weather provider order. Setting this replaces regional defaults.
# When omitted, mainland China uses qweather,open-meteo; Singapore uses
# open-meteo,nea-sg; Japan adds jma-jp when jma_office_code is set; other
# locations use open-meteo.
# WEATHER_PROVIDERS=qweather,open-meteo

# Optional official AI service-status monitoring. No status-page credentials
# are required. Leave empty to disable, or list any comma-separated subset of
# deepseek,openai,anthropic,kimi to enable independent monitoring.
SERVICE_STATUS_PROVIDERS=
# Only meaningful incident changes and recoveries are delivered. Official
# messages already in English or SERVICE_STATUS_LANGUAGE are forwarded unchanged;
# other languages are faithfully translated with the configured LLM.
# Comma-separated delivery platforms for status messages; defaults to PUBLISHER.
# SERVICE_STATUS_PUBLISHERS=telegram,bark
# Independent five-field cron schedule; the default runs every five minutes.
SERVICE_STATUS_CRON=*/5 * * * *
# Notification language: en, zh-CN, or ja.
SERVICE_STATUS_LANGUAGE=en

# Optional: QWeather JWT configuration.
# QWEATHER_PROJECT_ID=
# QWEATHER_CREDENTIAL_ID=
# QWEATHER_PRIVATE_KEY=
# QWEATHER_JWT_LIFETIME_SECONDS=900
# QWEATHER_API_HOST=

# Open-Meteo. API key is optional for the non-commercial free endpoint.
# OPEN_METEO_API_KEY=

# Optional: Singapore NEA/data.gov.sg public real-time API.
# NEA_API_KEY=

# Optional: AQICN air-quality.
# AQICN_API_TOKEN=

# Required: a private JSON file containing one or more locations. Each object
# requires a unique id and either a name or both latitude and longitude.
# See locations.example.json.
BRIEFING_LOCATIONS_FILE=locations.json

# Optional: private RSS sources. The file may be absent or contain an empty array.
RSS_SOURCES_FILE=rss-sources.json
RSS_FAILURE_THRESHOLD=3
RSS_MAX_ATTEMPTS=3
RSS_RETRY_MIN_SECONDS=3
RSS_RETRY_MAX_SECONDS=5
RSS_STALE_HOURS=24

# Optional: state persistence. The file may be absent or empty; it will be created and updated as needed.
BRIEFING_STATE_PATH=state/weather.sqlite3
GEOCODING_CACHE_PATH=state/geocoding.json
# GEOCODING_API_KEY=

# Optional: reliability tuning
WARNING_RETENTION_HOURS=12
HISTORY_HOURS=48
LLM_HISTORY_MAX_DOCUMENTS=8
LLM_HISTORY_MAX_CHARACTERS=16000
HTTP_TIMEOUT_SECONDS=30
